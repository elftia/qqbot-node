{
  "name": "@elftia/qqbot-node",
  "version": "1.0.0",
  "description": "QQ Bot SDK for Node.js — full-featured QQ Open Platform API v2 client with WebSocket gateway, rich media, SILK audio, and intent degradation",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "silk-wasm": "^3.7.1",
    "mpg123-decoder": "^1.0.3"
  },
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "qq",
    "qqbot",
    "qq-bot",
    "tencent",
    "bot",
    "sdk",
    "node",
    "websocket",
    "silk",
    "voice",
    "qq-open-platform"
  ],
  "author": "Elftia <https://github.com/elftia>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elftia/qqbot-node.git"
  },
  "homepage": "https://github.com/elftia/qqbot-node#readme",
  "bugs": {
    "url": "https://github.com/elftia/qqbot-node/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
